art_par <- list(
seed = 2,
n_paths = 500,
n_steps = 80
)
set.seed(seed = art_par$seed)
state <- tibble(
x = runif(n = art_par$n_paths, min = 0, max = 2),
y = runif(n = art_par$n_paths, min = 0, max = 2)
)
state <- state %>%
mutate(
path_id = 1:art_par$n_paths,
step_id = 1
)
art_dat <- state
stop_painting <- FALSE
while(stop_painting == FALSE) {
# Make a step
step <- curl_noise(
generator = gen_simplex,
x = state$x,
y = state$y,
seed = art_par$seed
)
state <- state %>%
mutate(
x = x + (step$x / 1000),
y = y + (step$y / 1000),
step_id = step_id + 1
)
# append the state to art_dat
art_dat <- bind_rows(art_dat, state)
if(last(state$step_id) >= art_par$n_steps) {
stop_painting <- TRUE
}
}
pic <- ggplot(art_dat, aes(x,y, group = path_id)) +
geom_path(size = .5,
alpha = .5)
print(pic)
pic <- ggplot(art_dat, aes(x,y, group = path_id)) +
geom_path(size = .5,
alpha = .5) +
coord_equal()
print(pic)
